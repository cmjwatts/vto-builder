# Required: Anthropic API key for the AI features — section drafting (/api/draft)
# and the conversational V/TO Coach (/api/coach).
# Set this in Netlify site settings → Environment variables.
# Never commit a real key to git.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: comma-separated origin allowlist for the /draft endpoint.
# Defaults to "*" in dev. In production, set to your deployed origin(s):
#   ALLOWED_ORIGINS=https://vto.ninety.io,https://vto-builder.netlify.app
ALLOWED_ORIGINS=
